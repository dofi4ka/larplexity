# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
# Comma-separated Telegram user ids allowed to use the bot. Empty = allow all (not recommended).
ALLOWED_USER_IDS=123456789

# LLM — OpenAI-compatible (DeepSeek by default)
LLM_API_KEY=sk-your-deepseek-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3

# Tools
TAVILY_API_KEY=tvly-your-key
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
MAX_WEBPAGE_CHARS=20000
MAX_SEARCH_RESULTS=8

# Storage
SQLITE_PATH=data/bot.db
UPLOADS_DIR=uploads
MAX_UPLOAD_BYTES=5242880
ALLOWED_UPLOAD_EXTENSIONS=.txt,.md,.csv,.json,.log,.py,.pdf

# Memory / RAG
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=8
INCLUDE_PRIOR_CHATS_BY_DEFAULT=true
PRIOR_CHATS_LIMIT=5
SUMMARIZE_EVERY_N_MESSAGES=20

# Rate limiting
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60

# Research
RESEARCH_MAX_QUERIES=5
RESEARCH_MAX_SOURCES=10

# Infra
LOG_LEVEL=INFO
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8080
CHATS_PAGE_SIZE=5
